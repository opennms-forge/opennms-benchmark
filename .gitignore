# === macOS specific ===

# Finder metadata
.DS_Store

# macOS folder attributes
.AppleDouble
.LSOverride

# Thumbnails
._*

# Icon files
.Spotlight-V100
.Trashes
.VolumeIcon.icns

# === IntelliJ IDEA specific ===

# IntelliJ project files and folders
.idea/
*.iml
*.iws
out/

# OS generated files (for all systems)
*.log

# === Terraform specific ===

# Terraform local state files
terraform.tfstate
terraform.tfstate.backup
*.tfstate
*.tfstate.*

# Crash logs
crash.log

# Exclude Terraform's .terraform directory which contains providers and modules downloaded by Terraform
**/.terraform/
.terraform.lock.hcl
**/.terraform.lock.hcl

# Sensitive variable files (uncomment if you don't want to commit your terraform variables)
# *.tfvars
# *.tfvars.json

# KVM tfvars contains a host-specific URI — gitignored, use kvm.tfvars.example as template
terraform/kvm/kvm.tfvars

# Proxmox tfvars contains an API token — gitignored, use proxmox.tfvars.example as template
terraform/proxmox/proxmox.tfvars

# VMware tfvars contains a vCenter password — gitignored, use vmware.tfvars.example as template
terraform/vmware/vmware.tfvars

# CLI config files
.terraformrc
terraform.rc

# Override tfvars files with local settings (optional)
# *.auto.tfvars

# === Claude Code / BMAD ===
.claude/
_bmad/
_bmad-output/

# === Ansible specific ===

# Generated by terraform/modules/inventory — contains env-specific IPs and key paths
ansible-inventory.yml

