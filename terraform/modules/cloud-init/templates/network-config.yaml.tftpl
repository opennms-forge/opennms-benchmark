version: 2
ethernets:
%{ for iface in interfaces ~}
  ${iface.name}:
%{ if iface.address != null ~}
    addresses:
      - ${iface.address}/${iface.prefix}
%{ if iface.gateway != null || length(iface.routes) > 0 ~}
    routes:
%{ if iface.gateway != null ~}
      - to: default
        via: ${iface.gateway}
%{ endif ~}
%{ for route in iface.routes ~}
      - to: ${route.to}
        via: ${route.via}
%{ endfor ~}
%{ endif ~}
    dhcp4: false
%{ else ~}
    dhcp4: true
%{ endif ~}
%{ endfor ~}
