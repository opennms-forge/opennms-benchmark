---
services:

  pgadmin:
    image: dpage/pgadmin4:latest
    deploy:
      resources:
        limits:
          cpus: 1.0
          memory: 512m
    environment:
      TZ: UTC
      PGADMIN_DEFAULT_EMAIL: "{{ pgadmin_default_email }}"
      PGADMIN_DEFAULT_PASSWORD: "{{ pgadmin_default_password }}"
      SCRIPT_NAME: /pgadmin
    volumes:
      - data-pgadmin:/var/lib/pgadmin
    ports:
      - "5050:80/tcp"

volumes:
  data-pgadmin: {}
