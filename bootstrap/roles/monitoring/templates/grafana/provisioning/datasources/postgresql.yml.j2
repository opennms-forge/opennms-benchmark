---
apiVersion: 1

datasources:
  - name: PostgreSQL
    type: postgres
    access: proxy
    database: {{ opennms_datasource_db_name }}
    url: {{ opennms_datasource_db_host }}:{{ opennms_datasource_db_port }}
    user: {{ opennms_datasource_db_user }}
    secureJsonData:
      password: {{ opennms_datasource_db_password }}
    jsonData:
      postgresVersion: 1500
      sslmode: disable
      tlsAuth: false
      tlsSkipVerify: true
      timescaledb: false
